# Copia a backend/.env y rellena (no commitear .env)

# Podcast IA — guion (OpenRouter) + audio (ElevenLabs). Solo backend.
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_MODEL_FALLBACK=openrouter/auto

ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_PERSON1=JBFqnCBsd6RMkjVDRZzb
# ELEVENLABS_VOICE_PERSON2=cgSgspJ2msm6clMCkdW9
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Ebooks con IA (Gamma). Sin clave, el backend genera un PDF mínimo de prueba.
GAMMA_API_KEY=
# GAMMA_DEV_MOCK=false

# Pagos Stripe (backend)
STRIPE_SECRET_KEY=

# Correo (verificación de cuenta y recibo de compra). Gmail: contraseña de aplicación.
SKILLNET_MAIL_ENABLED=false
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SKILLNET_MAIL_FROM=
# Nombre visible en la bandeja (ej. SkillNet). Con Gmail personal la dirección SMTP sigue siendo la tuya.
SKILLNET_MAIL_FROM_NAME=SkillNet
